---
import DocsLayout from "../../layouts/DocsLayout.astro";

const frontmatter = {
  title: "Acceptance Tests",
  showToc: false,
};

const suites = [
  {
    href: "/compliance/responses",
    label: "OpenAI Responses",
    description:
      "Validate any backend that implements the OpenAI Responses API surface.",
  },
  {
    href: "/compliance/chat-completions",
    label: "OpenAI Chat Completions",
    description:
      "Validate Chat Completions compatibility against the official OpenAI schema.",
  },
  {
    href: "/compliance/anthropic-messages",
    label: "Anthropic Messages",
    description:
      "Validate Anthropic Messages compatibility, including streaming events and tool use.",
  },
];
---

<DocsLayout frontmatter={frontmatter}>
  <h1 class="page-title">Acceptance Tests</h1>

  <p>
    Pick a specification suite to test any API endpoint for compliance. Each
    suite runs an independent set of templates against the chosen base URL and
    validates responses against the official OpenAPI schema.
  </p>

  <ul class="suite-list">
    {
      suites.map((suite) => (
        <li>
          <a href={suite.href}>
            <strong>{suite.label}</strong>
            <span>{suite.description}</span>
          </a>
        </li>
      ))
    }
  </ul>
</DocsLayout>

<style>
  .suite-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: grid;
    gap: 0.75rem;
  }
  .suite-list a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid #e7e5e4;
    border-radius: 0.5rem;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .suite-list a:hover {
    border-color: #fdba74;
  }
  .suite-list strong {
    display: block;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-bottom: 0.25rem;
  }
  .suite-list span {
    display: block;
    color: #57534e;
    font-size: 0.95rem;
  }
</style>

{
  "name": "llmprobe",
  "version": "0.1.1",
  "description": "Compliance test runner for LLM API endpoints (OpenAI Responses, Chat Completions, Anthropic Messages).",
  "bin": {
    "llmprobe": "bin/dist/llmprobe.mjs"
  },
  "files": [
    "bin/dist/llmprobe.mjs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prettier": "prettier",
    "build:cli": "esbuild bin/compliance-test.ts --bundle --platform=node --format=esm --target=node20 --outfile=bin/dist/llmprobe.mjs && chmod +x bin/dist/llmprobe.mjs",
    "prepare": "husky && npm run build:cli",
    "prepublishOnly": "npm run build:cli",
    "test:compliance": "bun run bin/compliance-test.ts",
    "test:compliance:responses": "bun run bin/compliance-test.ts --spec responses",
    "test:compliance:chat": "bun run bin/compliance-test.ts --spec chat-completions",
    "test:compliance:anthropic": "bun run bin/compliance-test.ts --spec anthropic-messages"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}

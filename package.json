{
  "name": "openresponses",
  "version": "0.1.0",
  "description": "OpenResponses",
  "main": "index.js",
  "scripts": {
    "tsp": "tsp compile schema__tsp/schema.tsp",
    "tsp:watch": "tsp compile schema__tsp/schema.tsp --watch",
    "spec:responses": "python bin/inline_openapi_refs.py --entrypoint ./schema/responses/openapi.json --endpoint 'POST /responses' --endpoint 'POST /responses/compact' --manifest ./schema/responses/openapi_filter_manifest.yaml --patches schema/responses/openapi_additive_patches.yaml --output ./public/openapi/responses.json && prettier --write --ignore-unknown ./public/openapi/responses.json && cp ./public/openapi/responses.json ./public/openapi/openapi.json",
    "spec:chat-completions": "python bin/inline_openapi_refs.py --entrypoint ./schema/chat-completions/openapi.json --endpoint 'POST /chat/completions' --output ./public/openapi/chat-completions.json && prettier --write --ignore-unknown ./public/openapi/chat-completions.json",
    "spec:anthropic-messages": "cp ./schema/anthropic-messages/openapi.json ./public/openapi/anthropic-messages.json && prettier --write --ignore-unknown ./public/openapi/anthropic-messages.json",
    "spec": "bun run spec:responses && bun run spec:chat-completions && bun run spec:anthropic-messages",
    "llms": "python3 bin/build_llms_txt.py",
    "generate:zod:responses": "kubb generate",
    "generate:zod:chat-completions": "kubb generate --config kubb.chat-completions.config.ts",
    "generate:zod:anthropic-messages": "kubb generate --config kubb.anthropic-messages.config.ts",
    "generate:zod": "bun run generate:zod:responses && bun run generate:zod:chat-completions && bun run generate:zod:anthropic-messages",
    "prettier": "prettier",
    "prepare": "husky",
    "dev:astro": "astro dev",
    "dev": "bun run spec && bun run llms && bun run dev:astro",
    "preview": "astro preview",
    "test:compliance": "bun run bin/compliance-test.ts",
    "test:compliance:responses": "bun run bin/compliance-test.ts --spec responses",
    "test:compliance:chat": "bun run bin/compliance-test.ts --spec chat-completions",
    "test:compliance:anthropic": "bun run bin/compliance-test.ts --spec anthropic-messages"
  },
  "author": "",
  "license": "ISC",
  "tspMain": "./schema/schema.tsp",
  "devDependencies": {
    "@kubb/cli": "^4.15.0",
    "@kubb/core": "^4.15.0",
    "@kubb/plugin-oas": "^4.15.0",
    "@kubb/plugin-zod": "^4.15.0",
    "@typespec/prettier-plugin-typespec": "^1.8.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@astrojs/mdx": "4.3.13",
    "@astrojs/react": "4.4.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vercel/analytics": "^1.6.1",
    "astro": "5.16.6",
    "astro-expressive-code": "^0.41.3",
    "astro-mermaid": "^1.2.0",
    "mermaid": "^11.12.2",
    "oas": "^28.8.2",
    "railroad-diagrams": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  }
}
